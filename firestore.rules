rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 200 chars)
    //   - slug: string (required, max 200 chars)
    //   - content: string (required, max 100000 chars)
    //   - excerpt: string (optional, max 500 chars)
    //   - coverImage: string (optional, max 1000 chars)
    //   - published: boolean (required)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //   - seoTitle: string (optional, max 100 chars)
    //   - seoDescription: string (optional, max 300 chars)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "tgff28970@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidPost() {
      return hasOnlyAllowedFields(['title', 'slug', 'content', 'excerpt', 'coverImage', 'published', 'createdAt', 'updatedAt', 'seoTitle', 'seoDescription']) &&
             hasRequiredFields(['title', 'slug', 'content', 'published', 'createdAt', 'updatedAt']) &&
             validStringLength('title', 1, 200) &&
             validStringLength('slug', 1, 200) &&
             validStringLength('content', 1, 100000) &&
             isValidOptionalString('excerpt', 0, 500) &&
             isValidOptionalString('coverImage', 0, 500000) &&
             request.resource.data.published is bool &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp &&
             isValidOptionalString('seoTitle', 0, 100) &&
             isValidOptionalString('seoDescription', 0, 300);
    }

    function isValidUser() {
      return hasOnlyAllowedFields(['role']) &&
             hasRequiredFields(['role']) &&
             request.resource.data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /posts/{postId} {
      // Anyone can read published posts. Admins can read all posts (including drafts).
      allow read: if resource.data.published == true || isAdmin();
      
      // Only admins can create, update, or delete posts.
      allow create: if isAdmin() && isValidPost();
      allow update: if isAdmin() && isValidPost() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create or update users (to prevent self-escalation)
      allow create: if isAdmin() && isValidUser();
      allow update: if isAdmin() && isValidUser();
      allow delete: if isAdmin();
    }
  }
}
